{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Lojia - sistema de vendas, estoque e pedidos para lojas.",
  "author": "Lojia",
  "main": "electron/main.js",
  "homepage": "/",
  "repository": {
    "type": "git",
    "url": "https://github.com/GiovaniBrunoDev/NextVendas.git"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "axios": "^1.11.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.23.16",
    "jszip": "^3.10.1",
    "lucide-react": "^0.536.0",
    "react": "^19.1.1",
    "react-date-range": "^2.0.1",
    "react-dom": "^19.1.1",
    "react-feather": "^2.0.10",
    "react-icons": "^5.5.0",
    "react-input-mask": "^2.0.4",
    "react-router-dom": "^7.7.1",
    "react-scripts": "5.0.1",
    "react-select": "^5.10.2",
    "react-toastify": "^11.0.5",
    "recharts": "^3.1.0",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "video:dev": "remotion studio src/remotion/index.jsx",
    "video:render": "remotion render src/remotion/index.jsx SalvarSiteIphone out/salvar-site-iphone.mp4",
    "electron:dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "desktop:build": "cross-env REACT_APP_API_URL=https://nextpdv.onrender.com npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "desktop:publish": "cross-env REACT_APP_API_URL=https://nextpdv.onrender.com npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish always",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "build": {
    "extends": null,
    "appId": "br.com.lojia.app",
    "productName": "Lojia",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "build-resources/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lojia"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "GiovaniBrunoDev",
        "repo": "NextVendas"
      }
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.466",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "remotion": "^4.0.466",
    "tailwindcss": "^3.4.3",
    "wait-on": "^9.0.10"
  }
}
